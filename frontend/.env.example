# FastAPI backend URL (for development, this proxies requests)
FASTAPI_URL=http://localhost:8001

# User-facing authentication for local frontend development
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=
AUTH_SESSION_SECRET=
# Role embedded in the JWT at login. Values: user | administrator
AUTH_USER_ROLE=administrator

# Public frontend auth flag
NEXT_PUBLIC_AUTH_ENABLED=false
# Role used by the UI when AUTH_ENABLED=false (auth is skipped).
# Set to "administrator" to access admin features in local dev without enabling auth.
# Defaults to "user" (safe) if unset.
NEXT_PUBLIC_AUTH_USER_ROLE=administrator

# Phase 2 chat workspace UI gate (kept false until workspace editing is shipped)
NEXT_PUBLIC_CHAT_WORKSPACE_ENABLED=false
