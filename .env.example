# Steuermann - Environment Variables
# This file is a template. Docker Compose uses values from `.env` at runtime.
# If `.env` already exists, values there take precedence over this example file.

# Profile identification
PROFILE_ID=starter

# Ingestion configuration
INGEST_COLLECTION=framework
INGEST_LANGUAGE=de
INGEST_LANGUAGE_THRESHOLD=0.8
INGEST_EMBEDDING_BATCH_SIZE=32
INGEST_UPSERT_BATCH_SIZE=128
INGEST_FILE_CONCURRENCY=2
INGEST_INCREMENTAL=true
INGEST_PHASE_TIMING=true
RAG_DATA_PATH=./data/rag-data
WORKSPACES_PATH=./data/workspaces

# Linux bind-mount permissions: set these to your host user's UID/GID
# before building images (e.g. APP_UID=$(id -u), APP_GID=$(id -g)).
APP_UID=1000
APP_GID=1000

# Runtime placeholders used by config validation and compose wiring
CHECKPOINTER_POSTGRES_DSN=postgresql://framework:framework@postgres:5432/framework
WEB_SEARCH_MCP_URL=http://duckduckgo-mcp:8000/mcp

# LLM provider configuration
#
# Supported chat providers so far:
# 1) Local Ollama
#    LLM_PROVIDERS_OLLAMA_API_BASE=http://host.docker.internal:11434/v1
#    OPENAI_API_KEY=lm-studio
#
# 2) Local LM Studio (OpenAI-compatible)
#    LLM_PROVIDERS_LMSTUDIO_API_BASE=http://host.docker.internal:1234/v1
#    OPENAI_API_KEY=lm-studio
#
# 3) OpenRouter.ai
#    LLM_PROVIDERS_OPENROUTER_API_BASE=https://openrouter.ai/api/v1
#    LLM_PROVIDERS_OPENROUTER_API_KEY=<your-openrouter-api-key>
#
# Provider endpoints (source of truth for llm.providers.*.api_base in config).
# Set the ones matching your active providers; unused entries can be left blank.
LLM_PROVIDERS_LMSTUDIO_API_BASE=http://host.docker.internal:1234/v1
LLM_PROVIDERS_OLLAMA_API_BASE=http://host.docker.internal:11434/v1
LLM_PROVIDERS_OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=lm-studio
LLM_PROVIDERS_OPENROUTER_API_KEY=

# LLM capability probing
# Set to false to disable probing entirely.
LLM_CAPABILITY_PROBE_ENABLED=true
# Set to false to skip automatic probe on FastAPI startup.
LLM_CAPABILITY_PROBE_ON_STARTUP=true
# Probe freshness threshold in seconds; stale probes cannot enable native mode.
LLM_CAPABILITY_PROBE_TTL_SECONDS=3600

# Embedding server (OpenAI-compatible API, e.g. LM Studio)
# Keep embeddings on LM Studio even when chat provider is Ollama/OpenRouter.
EMBEDDING_SERVER=http://host.docker.internal:1234/v1

# Database configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=framework
POSTGRES_PASSWORD=
POSTGRES_DB=framework

# Qdrant configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Monitoring

# ── User-Facing Authentication ────────────────────────────────────────
# Set AUTH_ENABLED=true to require a browser login. Leave false for local development.
# Note: effective runtime value is read from `.env` (or shell env), not from this template file.
AUTH_ENABLED=false
AUTH_USERNAME=admin
# Generate a password hash with:
# node -e "const c=require('node:crypto'); const salt=c.randomBytes(16).toString('base64url'); const hash=c.scryptSync(process.argv[1], salt, 64).toString('base64url'); console.log(`scrypt$${salt}$${hash}`)" "your-password"
# IMPORTANT: wrap AUTH_PASSWORD_HASH in single quotes to keep '$' literal in Docker Compose.
AUTH_PASSWORD_HASH=
# Generate a strong session secret: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SESSION_SECRET=

# ── Single-User Backend Identity ──────────────────────────────────────
# Generate a strong token: python -c "import secrets; print(secrets.token_hex(32))"
# Shared secret between Next.js and FastAPI. Leave blank only on a trusted network.
CHAT_ACCESS_TOKEN=

# ── Chat Attachments / Workspace ───────────────────────────
CHAT_ATTACHMENTS_ROOT=/tmp/steuermann-ai/chat-workspaces
CHAT_ATTACHMENTS_MAX_FILE_BYTES=524288
CHAT_ATTACHMENTS_RETENTION_HOURS=168
CHAT_WORKSPACE_ENABLED=false
# Optional dedicated workspace root (defaults to CHAT_ATTACHMENTS_ROOT/<conversation_id>/workspace)
CHAT_WORKSPACE_ROOT=
CHAT_WORKSPACE_RETENTION_HOURS=24

# Rate limiting (disable in automated load tests if needed)
RATE_LIMIT_ENABLED=true

# CORS: comma-separated extra origins appended to the built-in localhost list.
# Example: CORS_ORIGINS=https://myapp.example.com,https://staging.example.com
CORS_ORIGINS=

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Next.js Frontend ──────────────────────────────────────────────────
# NEXT_PUBLIC_* vars are baked in at build time AND passed at runtime.
# In Docker, NEXT_PUBLIC_AUTH_ENABLED is derived from AUTH_ENABLED automatically.
NEXT_PUBLIC_API_BASE=/api/proxy
NEXT_PUBLIC_SINGLE_USER_DISPLAY_NAME=Single User
NEXT_PUBLIC_SINGLE_USER_ROLE_LABEL=Local Profile
NEXT_PUBLIC_SINGLE_USER_EMAIL=

# ── Search ────────────────────────────────────────────────────────────
# BCP 47 region tag for DuckDuckGo search results (e.g. de-de, en-us, fr-fr)
SEARCH_REGION=de-de
