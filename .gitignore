# Python bytecode and cache
__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Test, type-checker and tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
htmlcov/
.coverage*
coverage.xml
.tox/
.nox/

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Local environment files
.env
.env.*
!.env.example
!**/.env.example

# Docker Compose overrides (local port configuration)
docker-compose.override.yml

# Local development files
docs/status.md
.github/
.vscode/
.idea/

# Profile overlays: keep template starter profile tracked, ignore local/custom overlays
/config/profiles/*/
!/config/profiles/starter/
!/config/profiles/starter/**

# Packaging/build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Frontend/build artifacts
node_modules/
.next/

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store

# Local RAG data
/data/rag-data/
/data/workspaces/
.docker-data/
